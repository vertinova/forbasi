generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model activity_log {
  id                     Int      @id @default(autoincrement())
  user_id                Int
  role_name              String?  @db.VarChar(50)
  user_role              String   @db.VarChar(50)
  self_idx               String   @db.VarChar(50)
  activity_type          String   @db.VarChar(100)
  description            String?  @db.Text
  application_id         Int?
  old_status             String?  @db.VarChar(50)
  new_status             String?  @db.VarChar(50)
  created_at             DateTime @default(now()) @db.Timestamp(0)
  approved_by_pergetA_id Int?

  @@index([user_id], map: "user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model activity_logs {
  id             Int      @id @default(autoincrement())
  user_id        Int
  role_name      String   @db.VarChar(50)
  activity_type  String   @db.VarChar(100)
  description    String?  @db.Text
  application_id Int?
  old_status     String?  @db.VarChar(50)
  new_status     String?  @db.VarChar(50)
  created_at     DateTime @default(now()) @db.Timestamp(0)

  @@index([application_id], map: "fk_activity_log_application")
  @@index([user_id], map: "fk_activity_log_user")
}

model admin_notifications {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String   @db.VarChar(255)
  message    String   @db.Text
  is_read    Boolean? @default(false)
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@index([user_id], map: "idx_admin_notifications_user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model admin_profiles {
  id              Int     @id @default(autoincrement())
  user_id         Int
  level           String? @db.VarChar(50)
  region          String? @db.VarChar(100)
  phone           String? @db.VarChar(20)
  additional_info String? @db.Text

  @@index([user_id], map: "user_id")
}

model cities {
  id          Int       @id @default(autoincrement())
  province_id Int
  name        String    @db.VarChar(255)
  provinces   provinces @relation(fields: [province_id], references: [id], onDelete: Cascade, map: "fk_city_province")
  users       users[]

  @@index([province_id], map: "fk_city_province")
}

