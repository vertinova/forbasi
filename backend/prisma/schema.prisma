}

model notifications {
  id         Int       @id @default(autoincrement())
  user_id    Int
  title      String    @db.VarChar(255)
  message    String    @db.Text
  type       String?   @default("general") @db.VarChar(50)
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notifications_ibfk_1")

  @@index([created_at], map: "idx_created_at")
  @@index([user_id], map: "idx_user_id")
}

model notifications_log {
  id                 Int                       @id @default(autoincrement())
  subscription_id    Int?
  title              String                    @db.VarChar(255)
  body               String                    @db.Text
  sent_at            DateTime?                 @default(now()) @db.Timestamp(0)
  status             notifications_log_status? @default(pending)
  error_message      String?                   @db.Text
  clicked_at         DateTime?                 @db.Timestamp(0)
  push_subscriptions push_subscriptions?       @relation(fields: [subscription_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notifications_log_ibfk_1")

  @@index([subscription_id], map: "subscription_id")
}

