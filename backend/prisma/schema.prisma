/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model kejurnas_categories {
  id                         Int                      @id @default(autoincrement())
  category_name              String                   @db.VarChar(100)
  level                      String                   @db.VarChar(50)
  quota_jawa                 Int                      @default(0)
  quota_luar_jawa            Int                      @default(0)
  quota_per_pengda_jawa      Int?                     @default(5)
  quota_per_pengda_luar_jawa Int?                     @default(3)
  created_at                 DateTime?                @default(now()) @db.Timestamp(0)
  kejurnas_registrations     kejurnas_registrations[]

  @@unique([category_name, level], map: "unique_category")
}

model kejurnas_events {
  id                     Int                      @id @default(autoincrement())
  event_name             String                   @db.VarChar(255)
  event_year             Int
  event_date             DateTime?                @db.Date
  location               String?                  @db.VarChar(255)
  description            String?                  @db.Text
  status                 kejurnas_events_status?  @default(upcoming)
  created_at             DateTime?                @default(now()) @db.Timestamp(0)
  updated_at             DateTime?                @default(now()) @db.Timestamp(0)
  kejurnas_registrations kejurnas_registrations[]

  @@unique([event_name, event_year], map: "unique_event")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model kejurnas_registrations {
  id                  Int                            @id @default(autoincrement())
  event_id            Int
  category_id         Int
  pengda_id           Int
  province_id         Int
  club_name           String                         @db.VarChar(255)
  club_id             Int?
  level               String                         @db.VarChar(50)
  is_jawa             Boolean                        @default(false)
  coach_name          String?                        @db.VarChar(255)
  coach_phone         String?                        @db.VarChar(20)
  manager_name        String?                        @db.VarChar(255)
  manager_phone       String?                        @db.VarChar(20)
  total_members       Int?
  notes               String?                        @db.Text
  logo_path           String?                        @db.VarChar(255)
  status              kejurnas_registrations_status? @default(pending)
  registered_at       DateTime?                      @default(now()) @db.Timestamp(0)
  approved_by         Int?
  approved_at         DateTime?                      @db.Timestamp(0)
  approval_status     String?                        @default("pending") @db.VarChar(20)
  approval_date       DateTime?                      @db.DateTime(0)
  approval_notes      String?                        @db.Text
  kejurnas_events     kejurnas_events                @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "kejurnas_registrations_ibfk_1")
  kejurnas_categories kejurnas_categories            @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "kejurnas_registrations_ibfk_2")
  users               users                          @relation(fields: [pengda_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "kejurnas_registrations_ibfk_3")
  provinces           provinces                      @relation(fields: [province_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "kejurnas_registrations_ibfk_4")

  @@index([category_id], map: "category_id")
  @@index([event_id, category_id], map: "idx_event_category")
  @@index([pengda_id], map: "idx_pengda")
  @@index([status], map: "idx_status")
  @@index([province_id], map: "province_id")
}

