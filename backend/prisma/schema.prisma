/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  id                     Int                      @id @default(autoincrement())
  username               String                   @unique(map: "username") @db.VarChar(50)
  password               String                   @db.VarChar(255)
  reset_token            String?                  @db.VarChar(255)
  reset_token_expires_at DateTime?                @db.DateTime(0)
  email                  String                   @unique(map: "email") @db.VarChar(100)
  phone                  String?                  @db.VarChar(20)
  address                String?                  @db.Text
  province_id            Int?
  city_id                Int?
  role_id                Int
  club_name              String?                  @db.VarChar(255)
  school_name            String?                  @db.VarChar(255)
  created_at             DateTime                 @default(now()) @db.Timestamp(0)
  updated_at             DateTime                 @default(now()) @db.Timestamp(0)
  bank_account_number    String?                  @db.VarChar(225)
  registration_fee       Decimal?                 @db.Decimal(10, 2)
  kejurnas_registrations kejurnas_registrations[]
  notifications          notifications[]
  cities                 cities?                  @relation(fields: [city_id], references: [id], map: "fk_user_city")
  provinces              provinces?               @relation(fields: [province_id], references: [id], map: "fk_user_province")
  roles                  roles                    @relation(fields: [role_id], references: [id], onDelete: NoAction, map: "fk_user_role")

  @@index([city_id], map: "fk_user_city")
  @@index([province_id], map: "fk_user_province")
  @@index([role_id], map: "fk_user_role")
}

model visitor_stats {
  id              Int       @id @default(autoincrement())
  visit_date      DateTime  @unique(map: "unique_date") @db.Date
  visit_count     Int?      @default(0)
  unique_visitors Int?      @default(0)
  created_at      DateTime? @default(now()) @db.Timestamp(0)
  updated_at      DateTime? @default(now()) @db.Timestamp(0)
}

enum pb_payments_recap_recipient_type {
  pengda
  pengcab
}

enum push_subscriptions_user_type {
